# Copy to `.env` and adjust. All keys use prefix YOUTUBE_SCRAPE_ (see Settings).

YOUTUBE_SCRAPE_LOG_LEVEL=INFO
YOUTUBE_SCRAPE_HEADLESS=true
YOUTUBE_SCRAPE_BROWSER_TIMEOUT_S=45
YOUTUBE_SCRAPE_HTTP_TIMEOUT_S=30
# Long timeout for full-file experimental download (no --max-bytes); httpx + browser GET use this floor.
# YOUTUBE_SCRAPE_MEDIA_DOWNLOAD_TIMEOUT_S=900
# Optional ms to wait after watch page load before scraping HTML (comments embed).
# YOUTUBE_SCRAPE_PAGE_SETTLE_AFTER_LOAD_MS=5000
YOUTUBE_SCRAPE_MAX_NAVIGATION_RETRIES=3
YOUTUBE_SCRAPE_NAVIGATION_BACKOFF_S=1.5
YOUTUBE_SCRAPE_HTTP_MAX_RETRIES=3
YOUTUBE_SCRAPE_COMMENTS_SAFETY_CEILING=50000
YOUTUBE_SCRAPE_OUTPUT_SCHEMA_VERSION=1
# YOUTUBE_SCRAPE_PROXY_SERVER=http://127.0.0.1:8080
# YOUTUBE_SCRAPE_USER_DATA_DIR=/path/to/firefox-profile
# Reuse one Camoufox for extract + media steps in the same session (recommended for downloads).
# YOUTUBE_SCRAPE_BROWSER_REUSE_CONTEXT=true
# Humanized pointer (Camoufox) for natural clicks (e.g. Skip on preroll ads).
# YOUTUBE_SCRAPE_CAMOUFOX_HUMANIZE=true
# Seconds to poll for skippable preroll after each watch navigation (0 disables).
# YOUTUBE_SCRAPE_YOUTUBE_PREROLL_AD_SKIP_BUDGET_S=55
#
# Missing public dislike counts: optionally GET Return YouTube Dislike `/votes` (community-maintained totals).
# YOUTUBE_SCRAPE_FETCH_RYD_VOTE_COUNTS=false
# YOUTUBE_SCRAPE_RYD_API_BASE_URL=https://returnyoutubedislikeapi.com
# YOUTUBE_SCRAPE_RYD_TIMEOUT_S=5
#
# Analytics LLM: `/analytics/ollama-report` and `/analytics/llm-probe` (comment macro brief).
# YOUTUBE_SCRAPE_ANALYTICS_OLLAMA_ENABLED=true
# ollama | openai_compatible | anthropic | google_gemini
# YOUTUBE_SCRAPE_ANALYTICS_LLM_PROVIDER=ollama
# Ollama
# YOUTUBE_SCRAPE_OLLAMA_BASE_URL=http://127.0.0.1:11434
# YOUTUBE_SCRAPE_OLLAMA_MODEL=gpt-oss:20b
# YOUTUBE_SCRAPE_OLLAMA_TIMEOUT_S=180
# Longer limit for POST /analytics/ollama-report only (large comment digest + JSON repair). Max 900.
# YOUTUBE_SCRAPE_ANALYTICS_MACRO_LLM_TIMEOUT_S=420
# OpenAI-compatible (OpenAI, Azure-style base URLs, LM Studio, vLLM, etc.)
# YOUTUBE_SCRAPE_OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
# YOUTUBE_SCRAPE_OPENAI_COMPATIBLE_API_KEY=
# YOUTUBE_SCRAPE_OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
# Anthropic
# YOUTUBE_SCRAPE_ANTHROPIC_BASE_URL=https://api.anthropic.com
# YOUTUBE_SCRAPE_ANTHROPIC_API_KEY=
# YOUTUBE_SCRAPE_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Google Gemini (Generative Language API)
# YOUTUBE_SCRAPE_GOOGLE_GEMINI_API_KEY=
# YOUTUBE_SCRAPE_GOOGLE_GEMINI_MODEL=gemini-2.0-flash
#
# Analytics chat RAG (Ollama embeddings only; per-scrape `.analytics_rag/` SQLite index).
# YOUTUBE_SCRAPE_ANALYTICS_RAG_ENABLED=true
# YOUTUBE_SCRAPE_OLLAMA_EMBED_MODEL=nomic-embed-text
# YOUTUBE_SCRAPE_ANALYTICS_RAG_TOP_K=12
# YOUTUBE_SCRAPE_ANALYTICS_RAG_MAX_CONTEXT_CHARS=24000
# Live progressive download test: headed browser by default (not a YOUTUBE_SCRAPE_ key — see tests).
# RUN_LIVE_REFERENCE_HEADFUL=0
